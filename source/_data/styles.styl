.demo-modal-open
  overflow hidden

.demo-modal-overlay
  position fixed
  inset 0
  z-index 1000
  background rgba(0, 0, 0, .72)
  backdrop-filter blur(6px)

.demo-modal
  position fixed
  inset 0
  z-index 1001
  display flex
  align-items center
  justify-content center
  padding 24px

.demo-modal[hidden],
.demo-modal-overlay[hidden]
  display none

.demo-modal-panel
  width min(1200px, 100%)
  max-height min(82vh, 860px)
  overflow auto
  padding 28px 30px 30px
  border 1px solid rgba(255, 255, 255, .08)
  border-radius 24px
  background #111
  box-shadow 0 24px 72px rgba(0, 0, 0, .42)

.demo-modal-head
  display flex
  align-items flex-start
  justify-content space-between
  gap 20px
  margin-bottom 22px
  padding-bottom 18px
  border-bottom 1px solid rgba(255, 255, 255, .08)

.demo-modal-kicker
  display inline-flex
  align-items center
  padding 6px 10px
  border 1px solid rgba(255, 255, 255, .08)
  border-radius 999px
  background rgba(255, 255, 255, .03)
  color #c7c7c7
  font-size 12px
  letter-spacing .12em
  text-transform uppercase

.demo-modal-head h2
  margin 14px 0 8px
  color #f2f2f2
  font-size clamp(28px, 4vw, 40px)
  line-height 1.05
  letter-spacing -.04em

.demo-modal-head p
  max-width 560px
  margin 0
  color #9a9a9a
  line-height 1.7

.demo-modal-close
  flex none
  width 42px
  height 42px
  border 1px solid rgba(255, 255, 255, .08)
  border-radius 12px
  background rgba(255, 255, 255, .03)
  color #f0f0f0
  font-size 26px
  line-height 1
  cursor pointer

.demo-modal-grid
  display grid
  grid-template-columns repeat(4, minmax(0, 1fr))
  gap 14px

.demo-card
  display flex
  flex-direction column
  min-height 180px
  padding 20px
  border 1px solid rgba(255, 255, 255, .08)
  border-radius 18px
  color #ececec
  text-decoration none
  background #161616
  transition transform .15s ease, border-color .15s ease, background .15s ease, box-shadow .15s ease

.demo-card:hover
  transform translateY(-1px)
  border-color rgba(255, 255, 255, .16)
  background #1a1a1a
  box-shadow 0 10px 28px rgba(0, 0, 0, .22)
  color #fff
  text-decoration none

.demo-card-badge
  display inline-flex
  align-items center
  justify-content center
  width fit-content
  margin-bottom 16px
  padding 6px 10px
  border 1px solid rgba(255, 255, 255, .08)
  border-radius 999px
  background rgba(255, 255, 255, .03)
  color #bdbdbd
  font-size 12px
  letter-spacing .1em
  text-transform uppercase

.demo-card strong
  display block
  margin-bottom 10px
  font-size 18px
  line-height 1.35

.demo-card-summary
  color #969696
  line-height 1.7

@media (max-width: 767px)
  .demo-modal
    align-items flex-end
    padding 12px

  .demo-modal-panel
    max-height 92vh
    padding 20px
    border-radius 18px

  .demo-modal-head
    flex-direction column

  .demo-modal-close
    position absolute
    top 18px
    right 18px

  .demo-modal-grid
    grid-template-columns 1fr
